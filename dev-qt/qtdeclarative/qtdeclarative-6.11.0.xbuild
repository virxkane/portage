DESCRIPTION="Qt toolkit (Declarative module)"

HOMEPAGE="http://www.qt.io/"

LICENSE="LGPL-2.1 GPL-3"

DEPEND="dev-lang/python"
RDEPEND=">=dev-qt/qtbase-${PV}
		>=dev-qt/qtlanguageserver-${PV}
		>=dev-qt/qtimageformats-${PV}
		>=dev-qt/qtshadertools-${PV}
		>=dev-qt/qtsvg-${PV}"

MY_P=${PN}-everywhere-src-${PV}

#SRC_URI="http://download.qt.io/official_releases/qt/6.11/${PV}/submodules/${MY_P}.tar.xz"
SRC_URI="https://qtproject.mirror.liquidtelecom.com/official_releases/qt/6.11/${PV}/submodules/${MY_P}.tar.xz"

SOURCES_DIR="${PN}-everywhere-src-${PV}"

USE_CMAKE=yes
CMAKE_GENERATOR=Ninja

src_configure()
{
	# Qt 6.11.0: quickcontrols2 style `fluentwinui3` build failed
	econf -DQT_FEATURE_quickcontrols2_fluentwinui3=OFF
}

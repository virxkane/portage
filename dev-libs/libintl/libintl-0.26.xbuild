DESCRIPTION="the GNU international library (split out of gettext)"

HOMEPAGE="http://www.gnu.org/software/gettext/gettext.html"

LICENSE="LGPL-2.1+"

MY_P="gettext-${PV}"

#   external dependencies
# perl (msys)

RDEPEND="sys-devel/libiconv"

SRC_URI="http://ftp.gnu.org/pub/gnu/gettext/${MY_P}.tar.xz"

SOURCES_DIR="${MY_P}/gettext-runtime"

src_configure()
{
	econf --enable-shared --enable-static \
		--enable-threads=posix \
		--without-emacs \
		--without-lispdir \
		--enable-nls \
		--with-included-gettext \
		--disable-c++ \
		--disable-libasprintf \
		--disable-java
}

src_compile()
{
	emake -C intl
}

src_install()
{
	emake_install DESTDIR="${INSTDIR}" -C intl
}

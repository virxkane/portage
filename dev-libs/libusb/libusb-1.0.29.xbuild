DESCRIPTION="Userspace access to USB devices"

HOMEPAGE="http://libusb.info/"

SRC_URI="https://github.com/libusb/libusb/releases/download/v${PV}/${P}.tar.bz2"

LICENSE="LGPL-2.1"

src_configure()
{
	econf --enable-shared --enable-static
}

src_compile()
{
	emake -j1
}

DESCRIPTION="Qt Creator is a cross-platform IDE for development with the Qt framework"

HOMEPAGE="https://wiki.qt.io/Category:Tools::QtCreator"

LICENSE="LGPL-2.1 LGPL-3"

MIN_QT_PV="6.11.0"

RDEPEND="sys-libs/zlib
		app-arch/zstd
		app-arch/libarchive
		dev-libs/libxml2
		media-libs/vulkan-loader
		>=dev-qt/qtbase-${MIN_QT_PV}
		>=dev-qt/qtsvg-${MIN_QT_PV}
		>=dev-qt/qttools-${MIN_QT_PV}
		>=dev-qt/qtdeclarative-${MIN_QT_PV}
		>=dev-qt/qt5compat-${MIN_QT_PV}
		>=dev-qt/qttranslations-${MIN_QT_PV}
		>=dev-qt/qtserialport-${MIN_QT_PV}
		>=dev-qt/qtquick3d-${MIN_QT_PV}
		dev-lang/python
		sys-devel/gdb
		dev-util/cmake
		dev-util/ninja
		sys-devel/clang"

MY_P=${PN}-opensource-src-${PV}

#SRC_URI="https://download.qt.io/official_releases/qtcreator/19.0/${PV}/${MY_P}.tar.xz"
SRC_URI="https://qtproject.mirror.liquidtelecom.com/official_releases/qtcreator/19.0/${PV}/${MY_P}.tar.xz"

SOURCES_DIR="${MY_P}"

USE_CMAKE=yes
CMAKE_GENERATOR=Ninja

src_configure()
{
	# with gcc-11 & pch build failed...
	econf \
		-DBUILD_WITH_PCH=OFF \
		-DWITH_TESTS=OFF \
		-DBUILD_EXECUTABLE_CMDBRIDGE=OFF
}

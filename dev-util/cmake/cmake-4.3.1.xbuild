DESCRIPTION="Cross platform Make"

HOMEPAGE="http://www.cmake.org/"

LICENSE="CMake"

# Don't add jsoncpp to avoid circular dependencies

RDEPEND="net-misc/curl
		dev-libs/expat
		sys-libs/zlib
		app-arch/libbz2
		>=app-arch/libarchive-3.3.3
		app-arch/xz-utils
		app-crypt/rhash
		>=dev-libs/libuv-1.38"

SRC_URI="http://www.cmake.org/files/v4.3/${P}.tar.gz"

src_configure()
{
	local have_cmake=n
	which cmake 2> /dev/null && have_cmake=y
	if [ "x${have_cmake}" = "xy" ]
	then
		mkdir ../cmake-build || eerror
		pushd ../cmake-build
		cmake -G "MSYS Makefiles" -DCMAKE_INSTALL_PREFIX="${PREFIX}" \
			-DCMAKE_BUILD_TYPE=Release \
			-DCMAKE_USE_SYSTEM_ZLIB=ON \
			-DCMAKE_USE_SYSTEM_BZIP2=ON \
			-DCMAKE_USE_SYSTEM_LIBLZMA=ON \
			-DCMAKE_USE_SYSTEM_ZSTD=ON \
			-DCMAKE_USE_SYSTEM_LIBARCHIVE=ON \
			-DCMAKE_USE_SYSTEM_CURL=ON \
			-DCMAKE_USE_SYSTEM_EXPAT=ON \
			-DCMAKE_USE_SYSTEM_LIBUV=OON \
			-DCMAKE_USE_SYSTEM_LIBRHASH=ON \
			-DCMAKE_USE_SYSTEM_JSONCPP=OFF \
			${WORKDIR}/${SOURCES_DIR}
		checkexitcode $? "cmake failed"
		popd
	else
		local opts=
		local nodes=`echo "${MAKEOPTS}" | sed -e 's/^-j\(.*\)$/\1/'`
		if [ "${nodes}" != "${MAKEOPTS}" -a "x${nodes}" != "x" ]
		then
			opts="--parallel=${nodes}"
		fi
		./bootstrap ${opts} \
			--prefix="${PREFIX}" \
			--system-zlib \
			--system-bzip2 \
			--system-liblzma \
			--system-zstd \
			--system-libarchive \
			--system-curl \
			--system-expat \
			--system-libuv \
			--system-librhash \
			--no-qt-gui \
			--verbose
		checkexitcode $? "bootstrap failed"
		# fix native path of install prefix back to MSYS path
		cat CMakeCache.txt | sed -e "s/^CMAKE_INSTALL_PREFIX:PATH=.*$/CMAKE_INSTALL_PREFIX:PATH=\\${PREFIX}/" > CMakeCache.txt.new
		mv -f CMakeCache.txt.new CMakeCache.txt
		cat cmake_install.cmake | sed -e "s/^\ *set(CMAKE_INSTALL_PREFIX\ .*)\ *$/  set(CMAKE_INSTALL_PREFIX\ \\${PREFIX})/" > cmake_install.cmake.new
		mv -f cmake_install.cmake.new cmake_install.cmake
	fi
}

src_compile()
{
	local need_popd=n
	if [ -d "${WORKDIR}/cmake-build" ]
	then
		pushd "${WORKDIR}/cmake-build"
		need_popd=y
	fi
	emake
	if [ "x${need_popd}" = "xy" ]
	then
		popd
	fi
}

src_install()
{
	local need_popd=n
	if [ -d "${WORKDIR}/cmake-build" ]
	then
		pushd "${WORKDIR}/cmake-build"
		need_popd=y
	fi
	emake_install
	if [ "x${need_popd}" = "xy" ]
	then
		popd
	fi
}

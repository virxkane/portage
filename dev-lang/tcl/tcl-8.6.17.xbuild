DESCRIPTION="Tool Command Language"

HOMEPAGE="http://www.tcl.tk/"

SRC_URI="https://downloads.sourceforge.net/tcl/${PN}-core${PV}-src.tar.gz"

LICENSE="tcltk Spencer-99"

DEPEND=""
RDEPEND="sys-libs/zlib"

SOURCES_DIR="${PN}${PV}/win"
BUILD_IN_SEPARATE_DIR=yes

src_prepare()
{
	pushd ..
	epatch "${P}-add-pkgconfig-file.patch"
	epatch "${P}-mingw-w64-system-zlib.patch"
	popd
	mv configure.in configure.ac
	cp ../unix/tcl.pc.in tcl.pc.in
	autoconf
}

src_configure()
{
	local opt_64bit=""
	case ${CHOST} in
	x86_64-w64-*)
		opt_64bit="--enable-64bit"
		# without options assumed 32 bit
		;;
	esac
	econf --enable-shared \
		--enable-threads \
		${opt_64bit}
}

src_install()
{
	emake_install INSTALL_ROOT="${INSTDIR}"
}

DESCRIPTION="PostgreSQL client libraries"

HOMEPAGE="https://www.postgresql.org/"

LICENSE="POSTGRESQL"

#   external dependencies:
# bison (msys)
# flex (msys)

RDEPEND="sys-libs/zlib
		app-arch/zstd
		dev-libs/openssl
		dev-libs/icu
		dev-libs/libxml2"

MY_PN="postgresql"
MY_P="${MY_PN}-${PV}"
SRC_URI="http://ftp.postgresql.org/pub/source/v${PV}/${MY_P}.tar.bz2"

SOURCES_DIR="${MY_P}"

# With libcurl we get an error:
#   configure: error: client-side OAuth is not supported on this platform

src_configure()
{
	econf --disable-nls \
		--with-zlib \
		--with-ssl=openssl \
		--with-icu \
		--with-libxml \
		--without-libcurl \
		--without-lz4 \
		--without-perl \
		--without-python \
		--without-tcl
}

src_compile()
{
	emake -C "src/port"
	emake -C "src/common"
	emake -C "src/interfaces/libpq"
	emake -C "src/bin/pg_config"
}

src_install()
{
	pushd "src/interfaces/libpq"
	emake_install
	rm -v "${INSTDIR}${PREFIX}/lib/libpq.dll"
	mv -v "${INSTDIR}${PREFIX}/lib/libpq.a" "${INSTDIR}${PREFIX}/lib/libpq.dll.a"
	popd

	pushd "src/include"
	touch utils/fmgroids.h
	touch utils/fmgrprotos.h
	emake_install
	popd

	pushd "src/bin/pg_config"
	emake_install
	popd
}

DESCRIPTION="PostgreSQL command line client"

HOMEPAGE="http://www.postgresql.org/"

LICENSE="POSTGRESQL"

#   external dependencies:
# bison (msys)
# flex (msys)
# perl (msys)

DEPEND="dev-libs/icu"
RDEPEND="dev-db/postgresql-libpq"

MY_PN="postgresql"
MY_P="${MY_PN}-${PV}"
SRC_URI="http://ftp.postgresql.org/pub/source/v${PV}/${MY_P}.tar.bz2"

SOURCES_DIR="${MY_P}"

src_configure()
{
	econf --disable-nls \
		--with-zlib \
		--with-ssl=openssl \
		--with-icu \
		--with-libxml \
		--without-libcurl \
		--without-lz4 \
		--without-perl \
		--without-python \
		--without-tcl
}

src_compile()
{
	emake -C "src/port"
	emake -C "src/common"
	emake -C "src/bin/psql"
}

src_install()
{
	mkdir -p ${INSTDIR}${PREFIX}/share/postgresql
	pushd "src/bin/psql"
	emake_install
	popd
}
